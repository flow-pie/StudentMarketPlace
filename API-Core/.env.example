#AFTER FILLING YOUR REAL CREDENTIALS SAVE THE FILE AS .env without .example extension

# ===================== DATABASE CONNECTIONS =====================

# MySQL URL (using pymysql driver)
MYSQL_URL=mysql+pymysql://<MYSQL_USER>:<MYSQL_PASSWORD>@localhost:3306/student_marketplace

# SQLite fallback URL (used for local development/testing)
SQLITE_URL=sqlite:///std_market.db

# Neon Postgres URL (ensure credentials are kept secure)
NEON_POSTGRES_URL=postgresql+psycopg2://<NEON_USER>:<NEON_PASSWORD>@<NEON_HOST>/<NEON_DB>?sslmode=require

# ===================== JWT AUTHENTICATION =====================

# Secret key for JWT token signing
JWT_SECRET_KEY=<your_jwt_secret_here>

# ===================== SUPABASE CONNECTION =====================

# Supabase credentials
USER=<your_supabase_user># e.g. postgres.abcd123xyz
PASSWORD=<your_supabase_password_raw># Plaintext before URL encoding

# Supabase connection details
HOST=aws-0-ap-south-1.pooler.supabase.com
PORT=5432
DBNAME=postgres

# Full Supabase URI (use URL-encoded password here)
#>>>>>>>>>
    # You can encode password using:
    # >>> import urllib.parse; urllib.parse.quote("your-password")
#<<<<<<<<<
SUPABASE_CONN="postgresql://<USER>:<URL_ENCODED_PASSWORD>@${HOST}:${PORT}/${DBNAME}"

#caching
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
